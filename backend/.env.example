BCM_PDF_PATH=data/Input/BCM/BCM Definitions.pdf
INPUT_EXTENSIONS=md,txt,json,csv,xml,log,dat,docx,pdf
INPUT_MAX_FILES=12
INPUT_MAX_CHARS=666000
