FOUNDRY_PROJECT_ENDPOINT=https://your-foundry-service.services.ai.azure.com/api/projects/your-foundry-project
FOUNDRY_MODEL=gpt-5.4
AGENT_NAME=DocsAgent
AGENT_INSTRUCTIONS=You are a friendly assistant. Keep your answers brief.
AGENT_PROMPT=Write a tagline for a budget-friendly eBike.
INPUT_FOLDER_PATH=data/Input/project/ProjectFolderName
